<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
  <style>
    *{
 	  font-family:"Times New Roman",serif;
      font-size:25px;	
      line-height:0.1;
 	 }
    .chair{
      width:40px;
      height:40px;
      background:#FFDD44;
      display:flex;
      align-items:center;
      justify-content:center;
      position:relative;
    }
    .block{
      width:50px;
      height:30px;
      background:#FFFFFF;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .Block{
      width:50px;
      height:30px;
      background:#FFFFFF;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .table{
      width:200px;
      height:200px;
      border-radius:50%;
      background:#5A89D9;
      display:flex;
	  align-items:center;
   	  justify-content:center;
      font-size:25px;
    }
    button{
      width:75px;
      height:33px;
    }
    input{
     width:175px;
     height:26px;
    }
  </style>

<title>文档标题</title>
</head>
<body>

<p style="position:absolute;font-weight:bold;font-size:35px;margin-left:25px;margin-top:8px;">Seating Arrangement Simulation</p>
<p style="position:absolute;margin-left:25px;margin-top:60px;">Choose 2 attendees to swap:</p>
<p style="position:absolute;margin-left:25px;margin-top:130px;">Enter Number of Attendees, Tables, Table Capacity and RI to Reset:</p>
<input id="i1" style="position:absolute;margin:0;left:30px;top:90px;">
<input id="i2" style="position:absolute;margin:0;left:225px;top:90px;">
<input id="i3" style="position:absolute;margin:0;left:30px;top:160px;">
<input id="i4" style="position:absolute;margin:0;left:225px;top:160px;">
<input id="i5" style="position:absolute;margin:0;left:420px;top:160px;">
<input id="i6" style="position:absolute;margin:0;left:615px;top:160px;">
<button id="b1" style="position:absolute;margin:0;left:420px;top:90px;"></button>
<button id="b2" style="position:absolute;margin:0;left:810px;top:160px;"></button>
<p id="SS" style="position:absolute;margin:0;margin-left:25px;margin-top:205px;">SS=0</p>
<p id="CP" style="position:absolute;margin:0;margin-left:220px;margin-top:205px;">CP=0</p>
<p id="RI" style="position:absolute;margin:0;margin-left:25px;margin-top:240px;">RI:</p>
<p id="NOTE" style="position:absolute;margin:0;left:35px;top:47px;font-size:17px;">Reminder: Please do not enter too large input or there may be a bug.We fix Seating Weights as 20,11,0.</p>
<script>
  let n=0,m=0,c=0,butt,reset,ml,il,Ml,Il,x,y,z,w,tp1,tp2,tp3,tp4,tp5,tp6,ss=0,cp=0,tps,tpcp,wn=20,wc=11,wa=0,Ss,Cp,Ri,text1,text2,ctop=265,leftoffset=0,tpn,tpm,tpc,RII;
  let r=Array.from({length:1010},()=>Array(1010).fill(0));
  let R=Array.from({length:1010},()=>Array(1010).fill(0));
  let a=Array.from({length:1010},()=>Array(1010).fill(0));
  let cppair=Array.from({length:1000010},()=>Array(2).fill(0));
  let CPLIST=Array.from({length:1000010},()=>Array(2).fill(0));
  let C=Array.from({length:1010},()=>Array(1010).fill(0)); //chair body
  let T=new Array(1010); //table body
  let p=new Array(1010);
  let tpr=new Array(1000010);
  let q=new Array(1000010);
  let b=new Array(1000010);
  let B=new Array(1000010);
  Ss=document.getElementById("SS");
  Cp=document.getElementById("CP");
  butt=document.getElementById("b1");
  reset=document.getElementById("b2");
  Ml=document.getElementById("i1");
  Il=document.getElementById("i2");
  butt.innerText="Swap";
  reset.innerText="Reset";
 
  reset.onclick=function(){
    tpn=Number(document.getElementById("i3").value);
    tpm=Number(document.getElementById("i4").value);
    tpc=Number(document.getElementById("i5").value);
    if(tpn<=0||tpm<=0||tpc<=0){
      alert("Invalid Input!(Number of attendees, tables or table capacity is not positive)");
   	  return;
    }
    if(tpn>tpm*tpc){
      alert("Invalid Input!(Too many attendees, overseated)");
   	  return;
    }
    RII=document.getElementById("i6").value.trim();
    let ip=1,nega=1;tpr[1]=0,badpoint=1;
    for(let j of RII){
      if(j==" "){
        if(badpoint==0) continue; 
        tpr[ip]*=nega,++ip,nega=1,tpr[ip]=0,badpoint=0;
      }
      else if(j=="-") nega=-1,badpoint=1;
      else if(!isNaN(Number(j))) tpr[ip]=tpr[ip]*10+Number(j),badpoint=1;
      else{
        alert("Invalid Input!(RI input not Numbers)");
        return;
      }
    }
    tpr[ip]*=nega;++ip;
    if(ip<=tpn*tpn){
     while(ip<=tpn*tpn) tpr[ip]=0,++ip; 
   }
    else if(ip>tpn*tpn+1){
      alert("Invalid Input!(To many RI values)");
      return;
    }
    n=tpn,m=tpm,c=tpc;
    document.querySelectorAll(".chair").forEach(t=>t.remove());
    document.querySelectorAll(".table").forEach(t=>t.remove());
    document.querySelectorAll(".block").forEach(t=>t.remove());
    ctop=265,leftoffset=0;
    for(let i=1;i<=n;i++){
    for(let j=1;j<=n;j++){
      r[i][j]=tpr[(i-1)*n+j];
      R[i][j]=document.createElement("div");
      R[i][j].className="block";
      R[i][j].id="b"+i+","+j;
      R[i][j].innerText=r[i][j];
      R[i][j].style.position="absolute";
      R[i][j].style.left=25+(j-1)*50+"px";
      R[i][j].style.top=ctop+"px";
      R[i][j].style.fontSize=20+"px";
      document.body.appendChild(R[i][j]);
    }
    ctop+=30;
   }
   ctop+=70;
   for(let i=1;i<=m;i++){
    T[i]=document.createElement("div");
    T[i].className="table";
    T[i].id="t"+i;
    T[i].style.position="absolute";
    T[i].style.left=105+leftoffset+"px";
    T[i].style.top=ctop+"px";
    T[i].style.backgroundColor="#5A89D9";   
    for(let j=1;j<=c;j++){
      C[i][j]=document.createElement("div");
      C[i][j].className="chair";
      C[i][j].id="c"+i+","+j;
      C[i][j].style.position="absolute";
      C[i][j].style.left=185+leftoffset-130*Math.cos(2*Math.PI*j/c)+"px";
      C[i][j].style.top=ctop+80-130*Math.sin(2*Math.PI*j/c)+"px";
      C[i][j].style.backgroundColor="#FFDD44";
      document.body.appendChild(C[i][j]);
    }
    if(i%4==0) ctop+=350,leftoffset=0;
    else leftoffset+=350;
    document.body.appendChild(T[i]);
   }
    ini();
  }
  
  
  butt.onclick=function(){
    ml=Number(Ml.value),il=Number(Il.value);
    if(isNaN(ml)||isNaN(il)){
      alert("Invalid Input!(Not a number)");
      return;
    }
    if(ml<=0||ml>m*c||il<=0||il>m*c){
      alert("Invalid Input!(Swapping out of range)");
      return;
    }
    x=p[ml],y=q[ml],z=p[il],w=q[il];
    tp1=a[x][y],tp2=a[z][w],tp3=p[ml],tp4=q[ml],tp5=p[il],tp6=q[il];
    a[x][y]=il,a[z][w]=ml,p[ml]=z,q[ml]=w,p[il]=x,q[il]=y;
    C[x][y].innerText=a[x][y]<=n?a[x][y]:(a[x][y]+"*");
    C[z][w].innerText=a[z][w]<=n?a[z][w]:(a[z][w]+"*");

    cal();
  ss=tps,cp=tpcp;
    Ss.innerText="SS="+ss;
   Cp.innerText="CP="+cp;
  }
  
  function cal(){
    document.querySelectorAll(".Block").forEach(t=>t.remove());
    tps=0,tpcp=0;
	for(let i=1;i<=m;i++){
		for(let j=1;j<=c;j++){
			for(let k=j+1;k<=c;k++){
                         	if(a[i][j]>n||a[i][k]>n) continue;
				if(r[a[i][j]][a[i][k]]<0) ++tpcp,cppair[tpcp][0]=a[i][j],cppair[tpcp][1]=a[i][k];
				else if((k-j+c-1)%c==0||(k-j+1)%c==0) tps+=wn*r[a[i][j]][a[i][k]];
				else tps+=wc*r[a[i][j]][a[i][k]];
			}
		}
	}
      CPLIST[0]=document.createElement("div");
      CPLIST[0].className="Block";
      CPLIST[0].id="CPLIST0";
      CPLIST[0].style.position="absolute";
      CPLIST[0].style.left=35+"px";
      CPLIST[0].style.top=ctop+300+"px";
      CPLIST[0].innerText="CP:";
      document.body.appendChild(CPLIST[0]);

	for(let i=1;i<=tpcp+10;i++){
      		for(let j=0;j<=1;j++){
      CPLIST[i][j]=document.createElement("div");
      CPLIST[i][j].className="Block";
      CPLIST[i][j].id="CPLIST"+i+","+j;
      CPLIST[i][j].style.position="absolute";
      CPLIST[i][j].style.left=25+j*50+"px";
      CPLIST[i][j].style.top=ctop+300+40*i+"px";
      CPLIST[i][j].style.fontSize=20+"px";
      CPLIST[i][j].innerText=(i<=tpcp)?cppair[i][j]:"";
      document.body.appendChild(CPLIST[i][j]);
	}
    }
  }
  function ini(){
    for(let i=1;i<=m;i++){
      b[i]=i;
    for(let j=1;j<=c;j++){
      a[i][j]=(i-1)*c+j;
      if(a[i][j]<=n) C[i][j].innerText=a[i][j]	;
      else C[i][j].innerText=a[i][j]+"*";
    }
    T[i].innerText="Table"+b[i];
  }
  for(let i=1;i<=m*c;i++){
    p[i]=~~((i-1)/c)+1,q[i]=((i-1)%c)+1;
  }
  cal();
  ss=tps,cp=tpcp;
  Ss.innerText="SS="+ss;
  Cp.innerText="CP="+cp;
  Ml.value="";
  Il.value=""; 
  }
</script>
</body>
</html>
